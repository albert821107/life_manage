# ==========================================
# 個人人生管理系統 v1 - 環境變數設定
# 複製此檔案為 .env 並填入你的值
# ==========================================

# 伺服器設定
PORT=3100
NODE_ENV=development

# SQLite 資料庫路徑 (自動建立)
DB_PATH=./data/life_manager.db

# ==========================================
# OpenAI - AI 助理
# 取得 API Key: https://platform.openai.com/api-keys
# 不設定時使用模擬模式
# ==========================================
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ==========================================
# LINE Notify - 即時通知
# 取得 Token: https://notify-bot.line.me/zh_TW/
# 不設定時關閉通知功能
# ==========================================
LINE_NOTIFY_TOKEN=your-line-notify-token-here

# ==========================================
# Telegram Bot - 即時通知
# 對 @BotFather 發送 /newbot 取得 Token
# 對 Bot 發訊後至 https://api.telegram.org/bot<TOKEN>/getUpdates 取得 chat.id
# ==========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# 每日摘要通知時間 (Cron 格式, 預設早上 8 點)
DAILY_NOTIFY_CRON=0 8 * * *
DAILY_NOTIFY_ENABLED=false

# ==========================================
# 進階功能（分析、投資進階、操盤）
# 設為 true 才會在左側導覽列顯示進階功能區塊
# ==========================================
ENABLE_ADVANCED=false

# ==========================================
# PM2 Reload 按鈕
# 設為 true 才會在右上角顯示 Reload 按鈕（直接重啟伺服器）
# 建議只在開發環境開啟
# ==========================================
ENABLE_RELOAD_BTN=false
