# 伺服器設定
PORT=3100
NODE_ENV=development

# SQLite 資料庫路徑（自動建立）
DB_PATH=./data/life_manager.db

# OpenAI - AI 助理（不填則使用模擬模式）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LINE Notify - 即時通知（不填則關閉）
LINE_NOTIFY_TOKEN=

# Telegram Bot - 即時通知（不填則關閉）
# 對 @BotFather 發送 /newbot 取得 Token
TELEGRAM_BOT_TOKEN=
# 對 Bot 發訊後至 https://api.telegram.org/bot<TOKEN>/getUpdates 取得 chat.id
TELEGRAM_CHAT_ID=

# 每日摘要推播設定
DAILY_NOTIFY_CRON=0 8 * * *
DAILY_NOTIFY_ENABLED=false

# Google 試算表同步（投資模組）
# 1. 開啟 Google 試算表 → 右上角「共用」→「知道連結的人可以檢視」
# 2. 從網址列複製 /d/ 與 /edit 之間的 ID 字串貼到下方
# 3. 試算表需有兩個工作表分頁，名稱固定為 Holdings 和 Transactions
# 4. Holdings 欄位：symbol | name | type | shares | avg_cost | current_price | note
# 5. Transactions 欄位：symbol | name | type | action | shares | price | date | note
#    type 可填：stock / etf / crypto / bond / other
#    action 可填：buy / sell
GOOGLE_SHEETS_ID='1AQLT9lfVqwS80x03V9pkZyDXX6IrsUclz50KVCL70K0'

# Google 試算表（資產總覽模組）
# 格式：A=單位, B=幣種, C=金額, D=匯率, E=換算台幣, F=佔比
#       H=統計日期, I=總金額(TWD)  （歷史紀錄欄）
#       K=幣種(TWD), L=匯率       （匯率參考欄）
# 試算表分頁名稱（若非第一頁請填寫分頁名稱，留空則讀第一頁）
GOOGLE_SHEETS_ASSETS_ID=
GOOGLE_SHEETS_ASSETS_SHEET=

# ==========================================
# 進階功能（分析、投資進階、操盤）
# 設為 true 才會在左側導覽列顯示進階功能區塊
# ==========================================
ENABLE_ADVANCED=true

# PM2 Reload 按鈕（右上角，設為 true 才顯示）
ENABLE_RELOAD_BTN=true

# 2-2 分析 - 加密金鑰 (AES-256-GCM)
ENCRYPT_KEY=80ea217c6e416dffc150df8f65dace3615e92a8616d9a031b995b204e84cfd9b

# 2-4 操盤 - Bybit API
BYBIT_API_KEY=l1TochxWAlyAvJTeq1
BYBIT_API_SECRET=DyGznoDWFnVMfZcd5rGpMUCk7uiA2eOIx8VK
BYBIT_TESTNET=false